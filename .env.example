# 复制为 `.env` 后填写真实值（`.env` 已加入 .gitignore，勿提交密钥）
# cp .env.example .env

# ---------- 运行 ----------
AMC_ENV=dev
AMC_LOG_LEVEL=INFO

# 可选：YAML 路径（实现加载配置时可读取）
# AMC_CONFIG_PATH=config/config.yaml

# ---------- 鉴权（MVP 可选）----------
# AMC_API_KEY=
# AMC_JWT_SECRET=

# ---------- Content（与 config.yaml storage.content_store.localfs_root 一致）----------
AMC_CONTENT_LOCAL_ROOT=./data/content

# ---------- Vector DB（默认 pgvector；可切换 AMC_VECTOR_STORE_BACKEND=chroma）----------
AMC_VECTOR_STORE_BACKEND=pgvector
AMC_PGVECTOR_DSN=postgresql://postgres:change-me@127.0.0.1:5432/postgres
AMC_PGVECTOR_SCHEMA=public
AMC_PGVECTOR_TABLE=amc_trajectory_index
# 可选：chroma 本地持久化目录（仅 backend=chroma 时使用）
AMC_CHROMA_PERSIST_DIR=./data/chroma

# ---------- Neo4j（必需）----------
AMC_NEO4J_URI=bolt://127.0.0.1:7687
AMC_NEO4J_USER=neo4j
AMC_NEO4J_PASSWORD=change-me
AMC_NEO4J_DATABASE=neo4j

# ---------- Embedding（indexing.async_enabled=true 时必需）----------
AMC_EMBEDDING_PROVIDER=openai
AMC_EMBEDDING_MODEL=doubao-embedding-vision-251215
AMC_EMBEDDING_MODE=multimodal
AMC_LLM_MODEL=gpt-4.1-mini
AMC_EMBEDDING_BASE_URL=
AMC_LLM_BASE_URL=
AMC_OPENAI_API_KEY=change-me
AMC_COMMIT_DATAFLOW_EXTRACTOR=llm
AMC_COMMIT_DATAFLOW_LLM_TEMPERATURE=0.0
AMC_COMMIT_REASONING_MIN_CONFIDENCE=0.55

# ---------- 事件与审计路径（与 config.yaml 中路径一致）----------
AMC_EVENT_JSONL_PATH=./data/events/amc_events.jsonl
AMC_AUDIT_FILE=./data/audit/amc_audit.log
